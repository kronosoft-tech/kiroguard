# KiroGuard Environment Variables Template
# Copy this file to .env for local testing (NEVER commit .env with real credentials!)

# AWS Credentials for Bedrock, Secrets Manager & SSM
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Server Options
KIROGUARD_TRANSPORT=sse
KIROGUARD_PORT=3000
KIROGUARD_LOG_FORMAT=json
KIROGUARD_AUTH_TOKEN=
